package pgrm3;
import org.testng.Assert;
import org.testng.annotations.Test;
public class LoginValidatorTest {
    @Test
    public void testValidLogin() {
        Assert.assertEquals(
            LoginValidator.validate("admin", "admin123"),
            "Login Successful"
        );
    }
    @Test
    public void testWrongPassword() {
        Assert.assertEquals(
            LoginValidator.validate("admin", "wrongpass"),
            "Login Failed"
        );
    }
    @Test
    public void testWrongUsername() {
        Assert.assertEquals(
            LoginValidator.validate("user", "admin123"),
            "Login Failed"
        );
    }
    @Test
    public void testNullUsername() {
        Assert.assertEquals(
            LoginValidator.validate(null, "admin123"),
            "Invalid Input"
        );
    }
    @Test
    public void testNullPassword() {
        Assert.assertEquals(
            LoginValidator.validate("admin", null),
            "Invalid Input"
        );
    }
}


